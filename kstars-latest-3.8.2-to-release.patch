+{
+  "version": "0.2.0",
+  "configurations": [
+    {
+      "name": "Debug KStars",
+      "type": "cppdbg",
+      "request": "launch",
+      "program": "${workspaceFolder}/build/kstars/kstars",
+      "args": [],
+      "stopAtEntry": false,
+      "cwd": "${fileDirname}",
+      "externalConsole": false,
+      "MIMode": "gdb",
+      "environment": [
+        {
+          "name": "LD_BIND_NOW",
+          "value": "1"
+        }
+      ],
+      "setupCommands": [
+        {
+          "description": "Enable pretty-printing for gdb",
+          "text": "-enable-pretty-printing",
+          "ignoreFailures": true
+        },
+        {
+          "description": "Set Disassembly Flavor to Intel",
+          "text": "-gdb-set disassembly-flavor intel",
+          "ignoreFailures": true
+        },
+        {
+          "text": "handle SIGPIPE nostop noprint pass"
+        },
+        {
+          "text": "skip -rfu ^std::.*"
+        },
+        {
+          "text": "skip file memory"
+        }
+      ],
+      "visualizerFile": "${workspaceFolder}/.vscode/qt6.natvis.xml",
+      "showDisplayString": true
+    },
+    {
+      "name": "Debug test_ekos_scheduler_ops (all)",
+      "type": "cppdbg",
+      "request": "launch",
+      "program": "${workspaceFolder}/build/Tests/kstars_ui/test_ekos_scheduler_ops",
+      "args": ["-v2"],
+      "stopAtEntry": false,
+      "cwd": "${workspaceFolder}/build/Tests/kstars_ui",
+      "externalConsole": false,
