index 6dc0b923a..471d8ec67 100644
--- a/Tests/kstars_ui/test_ekos_scheduler_ops.cpp
+++ b/Tests/kstars_ui/test_ekos_scheduler_ops.cpp
@@ -2947,6 +2947,171 @@ void TestEkosSchedulerOps::testWeatherMonitoringModeSimulator()
